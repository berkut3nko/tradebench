{
    "name": "tradebench/php-app",
    "description": "Backend API for TradeBench",
    "type": "project",
    "require": {
        "php": "^8.2",
        "grpc/grpc": "^1.57",
        "google/protobuf": "^3.25",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.5"
    },
    "config": {
        "allow-plugins": {
            "grpc/grpc": true
        },
        "audit": {
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "GPBMetadata\\": "proto/GPBMetadata/",
            "Analyzer\\": "proto/Analyzer/"
        }
    }
}