{
    "name": "tradebench/php-app",
    "description": "Backend API for TradeBench",
    "type": "project",
    "require": {
        "php": "^8.2",
        "grpc/grpc": "^1.74",
        "google/protobuf": "^3.25.5",
        "firebase/php-jwt": "^6.10.2",
        "vlucas/phpdotenv": "^5.5",
        "predis/predis": "^2.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "config": {
        "allow-plugins": {
            "grpc/grpc": true
        },
        "audit": {
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys",
                "PKSA-tcfz-w4fm-hhk9"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Tests\\": "tests/",
            "GPBMetadata\\": "proto/GPBMetadata/",
            "Analyzer\\": "proto/Analyzer/"
        }
    }
}